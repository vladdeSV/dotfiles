language en_US.UTF-8
syntax on
filetype plugin indent on
set nocompatible
set encoding=utf-8

let mapleader = ","

" editor general
set mouse=a
set tabstop=2
set softtabstop=2
set shiftwidth=2
set textwidth=0
set expandtab
set number
set numberwidth=4
set scrolloff=3
set wrap
set smartcase
set hlsearch
set incsearch
set linebreak
set laststatus=2
set statusline=%f%m\ %y%=%l/%L,%c " (based on https://nkantar.com/blog/2017/01/my-vim-statusline/)
set spelllang=en_us
set spellcapcheck= " disable capitalization
set whichwrap=bs<>hl[]
set autoindent
set fillchars+=vert:│
set listchars=tab:⎸\ 
set completeopt=menuone,noinsert,popup
set completepopup=border:off " ,highlight:PmenuSel
let &t_SI = "\e[6 q"
let &t_EI = "\e[2 q"
" workaround: when unsuspending vim, cursor is messed up
autocmd VimResume * call echoraw(&t_EI)
" disable "comment continuation" (gets overridden on load, have to resort to this)
autocmd FileType * set formatoptions-=ro
autocmd FileType markdown setlocal spell
autocmd FileType markdown setlocal complete+=kspell
hi LineNr ctermfg=7
hi VertSplit cterm=none ctermfg=0
" completion menu, to look a bit better imo
hi Pmenu ctermfg=15 ctermbg=0
hi PmenuMatch ctermfg=7 ctermbg=0
hi PmenuSel ctermfg=0 ctermbg=15
hi PmenuMatchSel ctermfg=8 ctermbg=15
" just a regular simple tabline, defaults look ass imo
hi TabLine cterm=underline ctermfg=none ctermbg=none
hi TabLineFill cterm=none ctermfg=none ctermbg=none
hi TabLineSel cterm=underline,reverse ctermbg=none ctermfg=none
hi SpecialKey ctermfg=7
" folds are hard on the eyes
hi Folded ctermfg=7 ctermbg=0
hi FoldColumn ctermbg=0
hi SpecialKey ctermfg=7

" ignore just a q press. h*ck i dislike this command...
map q <Nop>
" yank to clipboard
vnoremap <leader>c "+y
vnoremap <leader>y "+y
" move through softlines (based on https://stackoverflow.com/a/21000307)
nnoremap <expr> <Down> v:count ? 'j' : 'gj'
nnoremap <expr> <Up> v:count ? 'k' : 'gk'
" omnifunc
inoremap <expr> <C-Space> empty(&omnifunc) ? "\<C-x>\<C-n>" : "\<C-x>\<C-o>"
imap <C-@> <C-Space>

" if i yank to clipboard and then suspend vim, i can't paste in the terminal's cli
" workaround: new session of wl-copy if exists (on my non-wayland systems, i pray)
if executable('wl-copy')
  autocmd TextYankPost * if v:event.regname == '+' | call system('setsid wl-copy', join(v:event.regcontents, "\n")) | endif
endif

" plugin
call plug#begin("$HOME/.config/vim/plugged")

Plug 'tpope/vim-sensible' " insane default
Plug 'tpope/vim-fugitive' " use git in vim
Plug 'ntpeters/vim-better-whitespace' " ws
Plug 'airblade/vim-gitgutter' " git inline
Plug 'yegappan/lsp' " for language servers
Plug 'phelipetls/vim-hugo' " for hugo page
Plug 'terryma/vim-expand-region' " expands
Plug 'junegunn/vim-peekaboo' " in register
Plug 'preservim/nerdtree' " files explorer
Plug 'fatih/vim-go' " go syntax highlights

call plug#end()

" dim highlight of trailing whitespace
hi ExtraWhitespace ctermbg=7

" diff
hi SignColumn ctermbg=none
set updatetime=100
let g:gitgutter_map_keys = 0
nmap ghp <Plug>(GitGutterPreviewHunk)
nmap ghs <Plug>(GitGutterStageHunk)
nmap ghu <Plug>(GitGutterUndoHunk)
nmap gh. <Plug>(GitGutterNextHunk)
nmap gh, <Plug>(GitGutterPrevHunk)
nmap ghl :GitGutterLineHighlightsToggle<CR>

" neeeeeerdtree
hi Directory ctermfg=12
let g:NERDTreeShowHidden = 1
let g:NERDTreeWinPos = 'right'
let g:NERDTreeWinSize = 40
nnoremap <leader>ef :NERDTreeFocus<CR>
nnoremap <leader>ee :NERDTreeToggle<CR>
nnoremap <leader>ed :NERDTreeFind<CR>
let g:loaded_netrwPlugin = 1 " disable netrw in favor of NERDtree. i find netrw unstable to work with.

autocmd CompleteDone *.go if get(v:completed_item, 'kind', '') ==# 'f'
  \ && getline('.')[col('.') - 1] != '('
  \ | call feedkeys("()\<Left>", "n") | endif
